{
  "name": "@typedframe/core",
  "version": "0.0.1",
  "type": "module",
  "description": "A thin, type-safe React framework layer for Mantine, TanStack Query, Zod, and DnD Kit",
  "keywords": ["react", "mantine", "tanstack-query", "zod", "dnd-kit", "typescript"],
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/src/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint ."
  },
  "peerDependencies": {
    "@mantine/core": ">=9",
    "@mantine/form": ">=9",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-query": "^5.75.5",
    "axios": "^1.15.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@mantine/core": "9.1.1",
    "@mantine/form": "9.1.1",
    "@mantine/hooks": "9.1.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^6.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jsdom": "^29.0.1",
    "oxlint": "^1.58.0",
    "postcss": "^8.5.6",
    "postcss-preset-mantine": "1.18.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "6.0.3",
    "vite": "^8.0.5",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.0"
  }
}
